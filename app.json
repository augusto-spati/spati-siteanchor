{
  "expo": {
    "name": "Spati SiteAnchor",
    "slug": "spati-siteanchor",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "spatisiteanchor",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.spati.siteanchor",
      "infoPlist": {
        "NSCameraUsageDescription": "O Spati SiteAnchor usa a câmera para sobrepor o modelo BIM à realidade em AR.",
        "NSLocationWhenInUseUsageDescription": "O Spati SiteAnchor usa sua localização para georreferenciar o modelo no canteiro.",
        "NSPhotoLibraryUsageDescription": "O Spati SiteAnchor pode ler fotos para o AR.",
        "NSPhotoLibraryAddUsageDescription": "Allow $(PRODUCT_NAME) to save photos",
        "NSMicrophoneUsageDescription": "O Spati SiteAnchor usa o microfone para AR.",
        "GARAPIKey": "Your Google Cloud API Key",
        "RVApiKey": "Add your API key here",
        "RVProjectId": "Add your project ID here",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allow $(PRODUCT_NAME) to use your location for AR experiences"
      }
    },
    "android": {
      "package": "com.spati.siteanchor",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "@reactvision/react-viro",
        {
          "android": {
            "xRMode": "AR"
          },
          "ios": {
            "cameraUsagePermission": "O Spati SiteAnchor usa a câmera para AR.",
            "microphoneUsagePermission": "O Spati SiteAnchor usa o microfone para AR.",
            "photosPermission": "O Spati SiteAnchor pode ler fotos para o AR.",
            "savephotosPermission": "O Spati SiteAnchor pode salvar fotos durante o AR."
          },
          "googleCloudApiKey": "Your Google Cloud API Key",
          "provider": "reactvision",
          "rvApiKey": "Add your API key here",
          "rvProjectId": "Add your project ID here"
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "46001ce7-fb2e-4fc8-9970-7a7af16c336e"
      }
    }
  }
}
